# ─────────────────────────────────────────
# EGX-Nexus Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Infrastructure
NGINX_PORT=8080

# MySQL Database
MYSQL_ROOT_PASSWORD=change_me_strong_password
MYSQL_DATABASE=egxnexus
MYSQL_USER=egx_user
MYSQL_PASSWORD=change_me_strong_password

# TimescaleDB (PostgreSQL)
POSTGRES_PASSWORD=change_me_strong_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Broker — Thndr/TradingView credentials
TV_USERNAME=your_thndr_email@example.com
TV_PASSWORD=your_thndr_password
BROKER_ID=thndr

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Services
PROCESS_MODE=listener
AUTH_REFRESH_HOURS=12
HEADLESS_MODE=true
SYNC_INTERVAL_MS=30000
LOG_LEVEL=info
LOG_FORMAT=pretty
