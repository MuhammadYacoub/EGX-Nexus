NODE_ENV=development

MYSQL_ROOT_PASSWORD=egx_root_pass
MYSQL_DATABASE=egxnexus
MYSQL_PASSWORD=change_me_strong_password
MYSQL_URL=mysql+pymysql://root:egx_root_pass@mysql:3306/egxnexus

POSTGRES_PASSWORD=change_me_strong_password
REDIS_PASSWORD=change_me_strong_password
REDIS_URL=redis://redis:6379

JWT_SECRET=change_me_256bit_secret
VAULT_KEY=change_me_aes256_vault_key_32chars

OPENAI_API_KEY=sk-...

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DISCORD_BOT_TOKEN=your_discord_bot_token
TELEGRAM_CHAT_ID=your_chat_id

EGX_PLATFORM_USER=
EGX_PLATFORM_PASS=
MUBASHER_USER=
MUBASHER_PASS=

NEWS_API_KEY=
EGX_API_KEY=

# --- Deep Learning Engine Configuration ---
# Port for the DL Engine serving predictions (FastAPI)
DL_ENGINE_PORT=3008
# Enable GPU Support if the host machine has CUDA-capable hardware (true/false)
USE_GPU=false
# Preferred DL Framework: tensorflow | pytorch
DL_FRAMEWORK=pytorch
