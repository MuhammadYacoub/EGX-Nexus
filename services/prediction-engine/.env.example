# =============================================================================
# Chaimera Broker Gateway — Environment Configuration
# =============================================================================

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=chaimera:

# --- Broker Identity ---
BROKER_ID=tradingview

# --- WebSocket Listener ---
WS_MAX_RECONNECT_ATTEMPTS=50
WS_RECONNECT_BASE_DELAY_MS=1000
WS_RECONNECT_MAX_DELAY_MS=30000
WS_PING_INTERVAL_MS=0
WS_PONG_TIMEOUT_MS=10000

# --- Token Monitoring ---
TOKEN_CHECK_INTERVAL_S=60
TOKEN_REFRESH_THRESHOLD_S=120

# --- Auth Manager (Phase 2) ---
TV_USERNAME=
TV_PASSWORD=
HEADLESS_MODE=true
AUTH_REFRESH_HOURS=12

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=pretty

# --- Process Mode ---
# 'listener' = WSListener only
# 'auth'     = AuthManager only
PROCESS_MODE=listener